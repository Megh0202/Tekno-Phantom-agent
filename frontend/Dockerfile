FROM node:20-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=
ARG NEXT_PUBLIC_ADMIN_API_TOKEN=
ARG NEXT_PUBLIC_SHOW_ADVANCED_INPUTS=false

ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_ADMIN_API_TOKEN=$NEXT_PUBLIC_ADMIN_API_TOKEN
ENV NEXT_PUBLIC_SHOW_ADVANCED_INPUTS=$NEXT_PUBLIC_SHOW_ADVANCED_INPUTS

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-H", "0.0.0.0", "-p", "3000"]
