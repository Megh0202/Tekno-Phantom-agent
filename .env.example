# Shared
LOG_LEVEL=INFO

# Backend -> Brain
BRAIN_BASE_URL=http://localhost:8090
BRAIN_API_KEY=
BRAIN_TIMEOUT_SECONDS=10

# Backend API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:3000
ADMIN_API_TOKEN=
AUTH_ENABLED=true
AUTH_DATABASE_URL=sqlite:///data/auth.db
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRES_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRES_DAYS=7
AUTH_COOKIE_NAME=tekno_phantom_access
AUTH_REFRESH_COOKIE_NAME=tekno_phantom_refresh
AUTH_CSRF_COOKIE_NAME=tekno_phantom_csrf
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/
AUTH_COOKIE_DOMAIN=
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_IP_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_IDENTITY_MAX_ATTEMPTS=5

# Agent limits
MAX_STEPS_PER_RUN=20
STEP_TIMEOUT_SECONDS=60
DRAG_STEP_TIMEOUT_SECONDS=120

# Run persistence
RUN_STORE_BACKEND=sqlite
RUN_STORE_DB_PATH=data/run_store.sqlite3
SELECTOR_MEMORY_ENABLED=true
SELECTOR_MEMORY_BACKEND=sqlite
SELECTOR_MEMORY_DB_PATH=data/selector_memory.sqlite3
SELECTOR_MEMORY_MAX_CANDIDATES=5
SELECTOR_RECOVERY_ENABLED=true
SELECTOR_RECOVERY_ATTEMPTS=2
SELECTOR_RECOVERY_DELAY_MS=350
AUTO_DRAG_PRE_CLICK_ENABLED=true
AUTO_DRAG_POST_WAIT_MS=120
AUTO_LOGIN_WAIT_MS=500
AUTO_CREATE_CONFIRM_WAIT_MS=450
DEFAULT_WAIT_MS=450
PLANNER_DEFAULT_WAIT_MS=1000
RECOVERY_LOAD_STATE_WAIT_MS=10000
STRUCTURED_SELECTOR_WAIT_MS=6000
STRUCTURED_OPTIONS_WAIT_MS=5000

# Browser execution (BROWSER_MODE=playwright for direct Playwright, BROWSER_MODE=mcp for Playwright MCP)
BROWSER_MODE=mock
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=15000
PLAYWRIGHT_SLOW_MO_MS=0
BROWSER_VIEWER_ENABLED=false
DISPLAY_NUM=99
DISPLAY_SCREEN_GEOMETRY=1440x960x24
VIEWER_VNC_PORT=5900
VIEWER_WEB_PORT=6080
DRAG_USE_FIXED_COORDS=true
DRAG_TARGET_X_OFFSET=260
DRAG_TARGET_Y_OFFSET=180
DRAG_RETRY_RADIUS_PX=40
DRAG_VALIDATION_WAIT_MS=300
DRAG_MOUSE_STEPS=24
BROWSER_MCP_COMMAND=npx
BROWSER_MCP_PACKAGE=@playwright/mcp@latest
BROWSER_MCP_NPX_YES=true
BROWSER_MCP_READ_TIMEOUT_SECONDS=120

# File execution (set FILESYSTEM_MODE=mcp for real File MCP server integration)
FILESYSTEM_MODE=local
FILE_MCP_COMMAND=npx
FILE_MCP_PACKAGE=@modelcontextprotocol/server-filesystem
FILE_MCP_NPX_YES=true
FILE_MCP_READ_TIMEOUT_SECONDS=60

# Brain service provider selection
LLM_MODE=anthropic

# Local LLM (vLLM OpenAI-compatible endpoint)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=local-key
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Cloud LLM
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LOG_LEVEL=DEBUG